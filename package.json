{
  "name": "nxd-flow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @autopilot/engine --filter @autopilot/dashboard dev",
    "demo": "pnpm dev",
    "demo:cli": "pnpm -r build && pnpm autopilot -- demo",
    "verify": "pnpm -r build && pnpm autopilot -- verify",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -b --pretty false",
    "autopilot": "pnpm --filter @autopilot/cli autopilot"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
